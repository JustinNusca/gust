{
  "name": "gust",
  "version": "1.0.0",
  "description": "A CLI tool to generate Tailwind V4 theme files from Figma design tokens.",
  "author": "Justin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JustinNusca/gust.git"
  },
  "homepage": "https://github.com/JustinNusca/gust",
  "bugs": "https://github.com/JustinNusca/gust/issues",
  "main": "dist/index.js",
  "packageManager": "pnpm@10.33.4",
  "type": "module",
  "keywords": [
    "cli",
    "design-tokens",
    "figma",
    "react",
    "tailwind"
  ],
  "bin": {
    "gust": "./dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "readme.md",
    "LICENSE"
  ],
  "imports": {
    "#action/*": [
      "./src/action/*.ts",
      "./src/action/*/index.ts"
    ],
    "#prompt/*": [
      "./src/prompt/*.ts",
      "./src/prompt/*/index.ts"
    ],
    "#util/*": [
      "./src/util/*.ts",
      "./src/util/*/index.ts"
    ]
  },
  "scripts": {
    "build": "tsc",
    "dev": "GUST_DEBUG=true tsx src/index.ts",
    "format": "pnpm exec prettier . --check",
    "format:fix": "pnpm exec prettier . --write -l",
    "lint": "pnpm exec eslint .",
    "lint:fix": "pnpm exec eslint . --fix",
    "prepack": "tsc",
    "tsc": "pnpm exec tsc --noEmit --pretty"
  },
  "dependencies": {
    "@inquirer/prompts": "8.4.3",
    "@napi-rs/keyring": "^1.3.0",
    "boxen": "8.0.1",
    "chalk": "5.6.2",
    "commander": "14.0.3",
    "ora": "9.4.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@eslint/json": "1.2.0",
    "@eslint/markdown": "8.0.1",
    "@figma/rest-api-spec": "0.38.0",
    "@types/node": "25.7.0",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "globals": "17.6.0",
    "jiti": "2.7.0",
    "prettier": "3.8.3",
    "tsx": "4.22.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3"
  }
}
